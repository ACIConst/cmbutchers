rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function role() {
      return isSignedIn() && request.auth.token.role is string
        ? request.auth.token.role
        : null;
    }
    function isAdmin() { return isSignedIn() && request.auth.token.isAdmin == true; }
    function isStaff() { return isSignedIn() && request.auth.token.isStaff == true; }
    function isManager() { return isAdmin() && role() in ['Super Admin', 'Manager', 'Admin']; }
    function isDelivery() { return role() in ['Super Admin', 'Manager', 'delivery']; }

    // Menu & categories: public read, admin-only writes
    match /kioskMenu/{docId} {
      allow read: if true;
      allow update: if isAdmin();
      allow create, delete: if isAdmin();
    }
    match /kioskCategories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: created by trusted backend or managers only, authenticated read/update
    // Validates items array exists and each item quantity is ≤ 10
    match /kioskOrders/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() || isDelivery();
      allow delete: if false;
    }

    // Kiosk users: public create (self-registration), authenticated read/update
    match /kioskUsers/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isAdmin();
      // Self-update allowed but cannot change protected fields; admin staff can change anything
      allow update: if isAdmin()
        || (isSignedIn() && request.auth.uid == userId
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["role", "passwordHash", "createdAt", "createdBy"]));
      allow delete: if isAdmin();
    }
    // Admin accounts: authenticated read (behind OperatorGate), admin-only write
    match /kioskAdmins/{docId} {
      allow read, write: if isAdmin();
    }

    // App config: public read, manager-only writes
    // Validation: only allow incrementing lastNumber by 1, no other fields
    match /kioskConfig/orderCounter {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.data.keys().hasOnly(["lastNumber", "prefix"])
        && request.resource.data.lastNumber is int
        && request.resource.data.lastNumber == resource.data.lastNumber + 1;
    }
    match /kioskConfig/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Inventory adjustments: admin-only (only managers adjust stock via admin panel)
    match /inventoryAdjustments/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Audit logs: authenticated read/write from signed-in staff clients
    match /auditLogs/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.keys().hasAll(["action", "actorId", "actorName"])
        && request.resource.data.action is string
        && request.resource.data.action.size() < 100;
      allow update, delete: if isAdmin();
    }

    // QuickBooks tokens: deny ALL client access.
    // Only Cloud Functions (firebase-admin SDK) can read/write — it bypasses rules.
    match /qbTokens/{docId} {
      allow read, write: if false;
    }
    match /kioskSessions/{docId} {
      allow read, write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
